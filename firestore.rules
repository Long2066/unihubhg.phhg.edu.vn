rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Catch-all safety gate to deny any unspecified access
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Globally accessible variables and secure utility helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Checking if user is verified
    function isVerifiedUser() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.uid != null);
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }

    function isOwner(targetId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().targetId == targetId;
    }

    // 3. Entity Validator Utilities
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128
        && data.username is string && data.username.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.role is string && data.role.size() <= 32
        && data.email is string && data.email.size() <= 128;
    }

    function isValidStudent(data) {
      return data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 128
        && data.classId is string && data.classId.size() <= 64
        && data.facultyId is string && data.facultyId.size() <= 64
        && data.email is string && data.email.size() <= 128;
    }

    function isValidOrganization(data) {
      return data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 256
        && data.type is string && (data.type == 'CLB' || data.type == 'DOAN' || data.type == 'HOI')
        && data.leaderName is string && data.leaderName.size() <= 128
        && data.field is string && data.field.size() <= 256
        && data.level is string && (data.level == 'TRUONG' || data.level == 'KHOA');
    }

    function isValidMember(data) {
      return data.id is string && data.id.size() <= 128
        && data.studentId is string && data.studentId.size() <= 128
        && data.classId is string && data.classId.size() <= 64
        && data.orgId is string && data.orgId.size() <= 64
        && data.role is string && data.role.size() <= 64
        && data.joinedDate is string && data.joinedDate.size() <= 64
        && data.status is string && data.status.size() <= 64;
    }

    function isValidClubAnnouncement(data) {
      return data.id is string && data.id.size() <= 128
        && data.orgId is string && data.orgId.size() <= 64
        && data.orgName is string && data.orgName.size() <= 256
        && data.title is string && data.title.size() <= 256
        && data.content is string && data.content.size() <= 5000
        && data.createdAt is string && data.createdAt.size() <= 64;
    }

    // Checking validation for activities
    function isValidActivity(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 256
        && data.orgId is string && data.orgId.size() <= 64
        && data.orgName is string && data.orgName.size() <= 256
        && data.criteriaId is string && data.criteriaId.size() <= 64
        && data.points is number && data.points <= 100
        && data.dateTime is string && data.dateTime.size() <= 64
        && data.location is string && data.location.size() <= 256
        && data.status is string && (data.status == 'UPCOMING' || data.status == 'ONGOING' || data.status == 'COMPLETED');
    }

    function isValidActivityAttendance(data) {
      return data.id is string && data.id.size() <= 128
        && data.activityId is string && data.activityId.size() <= 128
        && data.studentId is string && data.studentId.size() <= 64
        && data.studentName is string && data.studentName.size() <= 128
        && data.classId is string && data.classId.size() <= 64
        && data.role is string && (data.role == 'MEM' || data.role == 'BTC' || data.role == 'SUPPORTER')
        && data.attended is bool
        && data.verified is bool;
    }

    function isValidEvidenceSubmission(data) {
      return data.id is string && data.id.size() <= 128
        && data.studentId is string && data.studentId.size() <= 64
        && data.studentName is string && data.studentName.size() <= 128
        && data.classId is string && data.classId.size() <= 64
        && data.criteriaId is string && data.criteriaId.size() <= 64
        && data.activityName is string && data.activityName.size() <= 256
        && data.pointsRequested is number && data.pointsRequested <= 100
        && data.proofUrl is string && data.proofUrl.size() <= 1024
        && data.submittedAt is string && data.submittedAt.size() <= 64
        && data.status is string && (data.status == 'PENDING' || data.status == 'APPROVED' || data.status == 'REJECTED');
    }

    function isValidEvaluationResult(data) {
      return data.studentId is string && data.studentId.size() <= 64
        && data.studentName is string && data.studentName.size() <= 128
        && data.classId is string && data.classId.size() <= 64
        && data.facultyId is string && data.facultyId.size() <= 64
        && data.periodId is string && data.periodId.size() <= 64
        && data.studyPoints is number
        && data.violationPoints is number
        && data.extracurricularPoints is number
        && data.communityPoints is number
        && data.achievementPoints is number
        && data.totalPoints is number
        && data.grade is string && (data.grade == 'XUẤT SẮC' || data.grade == 'TỐT' || data.grade == 'KHÁ' || data.grade == 'TRUNG BÌNH' || data.grade == 'YẾU' || data.grade == 'KÉM')
        && data.status is string && (data.status == 'AUTO' || data.status == 'PENDING_CLASS' || data.status == 'APPROVED_CLASS' || data.status == 'APPROVED_ADVISER' || data.status == 'LOCKED');
    }

    function isValidDailyAttendanceReport(data) {
      return data.id is string && data.id.size() <= 128
        && data.classId is string && data.classId.size() <= 64
        && data.date is string && data.date.size() <= 64
        && data.totalStudents is number
        && data.presentCount is number
        && data.absentCount is number
        && data.reportedBy is string && data.reportedBy.size() <= 128
        && data.reportedAt is string && data.reportedAt.size() <= 64;
    }

    // 4. Secure Collections Match rules
    match /users/{userId} {
      allow get, list: if isVerifiedUser();
      allow create: if isVerifiedUser() && isValidId(userId) && (
        (userId == request.auth.uid && incoming().role == 'STUDENT') || hasRole('ADMIN')
      ) && isValidUser(incoming());
      allow update: if isVerifiedUser() && isValidId(userId) && (
        hasRole('ADMIN') || (
          userId == request.auth.uid && 
          incoming().role == existing().role && 
          incoming().targetId == existing().targetId &&
          incoming().id == existing().id
        )
      ) && isValidUser(incoming());
      allow delete: if isVerifiedUser() && isValidId(userId) && hasRole('ADMIN');
    }

    match /students/{studentId} {
      allow get, list: if isVerifiedUser();
      allow create, delete: if isVerifiedUser() && isValidId(studentId) && (hasRole('ADMIN') || hasRole('TRAINING_DEPT'));
      allow update: if isVerifiedUser() && isValidId(studentId) && (
        hasRole('ADMIN') || 
        hasRole('TRAINING_DEPT') || 
        (
          studentId == request.auth.uid && 
          incoming().classId == existing().classId && 
          incoming().facultyId == existing().facultyId && 
          incoming().id == existing().id &&
          incoming().gpa == existing().gpa && 
          incoming().creditsEarned == existing().creditsEarned && 
          incoming().learningWarning == existing().learningWarning && 
          incoming().learningStatus == existing().learningStatus && 
          incoming().learningDataLocked == existing().learningDataLocked
        )
      ) && isValidStudent(incoming());
    }

    match /organizations/{orgId} {
      allow get, list: if isVerifiedUser();
      allow create, delete: if isVerifiedUser() && isValidId(orgId) && hasRole('ADMIN');
      allow update: if isVerifiedUser() && isValidId(orgId) && (
        hasRole('ADMIN') || (hasRole('ORGANIZER') && isOwner(orgId))
      ) && isValidOrganization(incoming());
    }

    match /members/{memberId} {
      allow get, list: if isVerifiedUser();
      allow create: if isVerifiedUser() && isValidId(memberId) && (
        hasRole('ADMIN') || 
        (hasRole('STUDENT') && incoming().studentId == getUserData().targetId && incoming().status == 'PENDING' && incoming().role == 'THÀNH VIÊN') ||
        (hasRole('ORGANIZER') && incoming().orgId == getUserData().targetId)
      ) && isValidMember(incoming());
      allow update: if isVerifiedUser() && isValidId(memberId) && (
        hasRole('ADMIN') || 
        (hasRole('ORGANIZER') && existing().orgId == getUserData().targetId && incoming().orgId == existing().orgId)
      ) && isValidMember(incoming());
      allow delete: if isVerifiedUser() && isValidId(memberId) && (
        hasRole('ADMIN') || 
        (hasRole('ORGANIZER') && existing().orgId == getUserData().targetId) ||
        (hasRole('STUDENT') && existing().studentId == getUserData().targetId)
      );
    }

    match /announcements/{announcementId} {
      allow get, list: if isVerifiedUser();
      allow create: if isVerifiedUser() && isValidId(announcementId) && (hasRole('ADMIN') || (hasRole('ORGANIZER') && incoming().orgId == getUserData().targetId)) && isValidClubAnnouncement(incoming());
      allow update: if isVerifiedUser() && isValidId(announcementId) && (hasRole('ADMIN') || (hasRole('ORGANIZER') && incoming().orgId == getUserData().targetId && existing().orgId == getUserData().targetId)) && isValidClubAnnouncement(incoming());
      allow delete: if isVerifiedUser() && isValidId(announcementId) && (hasRole('ADMIN') || (hasRole('ORGANIZER') && existing().orgId == getUserData().targetId));
    }

    match /activities/{activityId} {
      allow get, list: if isVerifiedUser();
      allow create: if isVerifiedUser() && isValidId(activityId) && (hasRole('ADMIN') || (hasRole('ORGANIZER') && incoming().orgId == getUserData().targetId)) && isValidActivity(incoming());
      allow update: if isVerifiedUser() && isValidId(activityId) && (hasRole('ADMIN') || (hasRole('ORGANIZER') && incoming().orgId == getUserData().targetId && existing().orgId == getUserData().targetId)) && isValidActivity(incoming());
      allow delete: if isVerifiedUser() && isValidId(activityId) && (hasRole('ADMIN') || (hasRole('ORGANIZER') && existing().orgId == getUserData().targetId));
    }

    match /attendance/{attendanceId} {
      allow get, list: if isVerifiedUser();
      allow create: if isVerifiedUser() && isValidId(attendanceId) && (
        hasRole('ADMIN') || 
        (hasRole('STUDENT') && incoming().studentId == getUserData().targetId && incoming().attended == false && incoming().verified == false && incoming().role == 'MEM') ||
        (hasRole('ORGANIZER') && get(/databases/$(database)/documents/activities/$(incoming().activityId)).data.orgId == getUserData().targetId)
      ) && isValidActivityAttendance(incoming());
      allow update: if isVerifiedUser() && isValidId(attendanceId) && (
        hasRole('ADMIN') || 
        (hasRole('ORGANIZER') && get(/databases/$(database)/documents/activities/$(existing().activityId)).data.orgId == getUserData().targetId)
      ) && isValidActivityAttendance(incoming());
      allow delete: if isVerifiedUser() && isValidId(attendanceId) && (
        hasRole('ADMIN') || 
        (hasRole('ORGANIZER') && get(/databases/$(database)/documents/activities/$(existing().activityId)).data.orgId == getUserData().targetId) ||
        (hasRole('STUDENT') && existing().studentId == getUserData().targetId && existing().verified == false)
      );
    }

    match /evidence/{evidenceId} {
      allow get, list: if isVerifiedUser();
      allow create: if isVerifiedUser() && isValidId(evidenceId) && (
        hasRole('ADMIN') || 
        (hasRole('STUDENT') && incoming().studentId == getUserData().targetId && incoming().status == 'PENDING')
      ) && isValidEvidenceSubmission(incoming());
      allow update: if isVerifiedUser() && isValidId(evidenceId) && (
        hasRole('ADMIN') || 
        ((hasRole('ADVISER') || hasRole('CLASS_MONITOR')) && getUserData().targetId == existing().classId) ||
        (hasRole('STUDENT') && existing().studentId == getUserData().targetId && existing().status == 'PENDING' && incoming().status == 'PENDING' && incoming().studentId == existing().studentId)
      ) && isValidEvidenceSubmission(incoming());
      allow delete: if isVerifiedUser() && isValidId(evidenceId) && (
        hasRole('ADMIN') || 
        (existing().studentId == getUserData().targetId && existing().status == 'PENDING')
      );
    }

    match /results/{resultId} {
      allow get, list: if isVerifiedUser();
      allow create, update: if isVerifiedUser() && isValidId(resultId) && (
        hasRole('ADMIN') || (
          (existing() == null || existing().status != 'LOCKED') && (
            (hasRole('ADVISER') && getUserData().targetId == existing().classId) ||
            (hasRole('CLASS_MONITOR') && getUserData().targetId == existing().classId) ||
            (hasRole('FACULTY') && getUserData().targetId == existing().facultyId) ||
            (hasRole('STUDENT') && incoming().studentId == getUserData().targetId && incoming().status == 'AUTO' && (existing() == null || incoming().adviserNotes == existing().adviserNotes))
          )
        )
      ) && isValidEvaluationResult(incoming());
      allow delete: if isVerifiedUser() && isValidId(resultId) && hasRole('ADMIN');
    }

    match /dailyAttendance/{attendanceId} {
      allow get, list: if isVerifiedUser();
      allow create, update: if isVerifiedUser() && isValidId(attendanceId) && (
        hasRole('ADMIN') || 
        (hasRole('CLASS_MONITOR') && getUserData().targetId == incoming().classId) ||
        (hasRole('ADVISER') && getUserData().targetId == incoming().classId)
      ) && isValidDailyAttendanceReport(incoming());
      allow delete: if isVerifiedUser() && isValidId(attendanceId) && (
        hasRole('ADMIN') || 
        (hasRole('CLASS_MONITOR') && getUserData().targetId == existing().classId) ||
        (hasRole('ADVISER') && getUserData().targetId == existing().classId)
      );
    }

  }
}
